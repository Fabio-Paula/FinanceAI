# =============================================================================
# FinanceAI — variáveis de ambiente
# Copie para .env.local e preencha os valores
# =============================================================================

# PostgreSQL — ajuste user, password, host e dbname
DATABASE_URL="postgresql://user:password@localhost:5432/financeai?schema=public"

# JWT — gere com: openssl rand -base64 32
JWT_SECRET="your-secret-key-here-change-in-production"

# API Port
PORT=3001

# IA (opcional)
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
