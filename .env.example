# =============================================================================
# Entrafy — variáveis de ambiente
# Copie para .env e preencha os valores
# =============================================================================

# PostgreSQL — ajuste user, password, host e dbname
DATABASE_URL="postgresql://user:password@localhost:5432/entrafy?schema=public"

# JWT — gere com: openssl rand -base64 32
JWT_SECRET="your-secret-key-here-change-in-production"

# API Port
PORT=3001

# IA (opcional) — configure a chave do provedor que for usar
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GEMINI_API_KEY=""
